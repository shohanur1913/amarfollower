# ----------------------------------------------------------------------
# 1. SECURITY: PROTECT DIRECTORIES
# ----------------------------------------------------------------------
Options -Indexes -MultiViews
RewriteEngine On
RewriteBase /amarfollower/

# ----------------------------------------------------------------------
# 2. SSL: FORCE HTTPS (DISABLED FOR LOCALHOST)
# ----------------------------------------------------------------------
# RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1) [NC]
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------------
# 3. CLEANUP: HIDE index.php FROM ADDRESS BAR
# ----------------------------------------------------------------------
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index\.php [NC]
RewriteRule ^ %1/ [R=301,L]

# ----------------------------------------------------------------------
# 4. API & FILES: PRESERVE REAL FILES (Crucial for /api directory)
# ----------------------------------------------------------------------
# If the request is for an actual existing file (like /api/place_order.php)
# or an existing directory, load it normally and stop rewriting.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Map /api/v2 to the v2.php file silently
RewriteRule ^api/v2$ api/v2.php [L,QSA]

# ----------------------------------------------------------------------
# 5. EXTENSIONS: HIDE .php AND ALLOW CLEAN ACCESS
# ----------------------------------------------------------------------
# If user visits /login, internally use login.php if it exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# ----------------------------------------------------------------------
# 6. ADMIN SPA ROUTING
# ----------------------------------------------------------------------
# Routes amarfollower.com/admin/users -> amarfollower.com/admin/index.php?p=users
RewriteCond %{REQUEST_URI} /admin/
RewriteRule ^admin/(.*)$ admin/index.php?p=$1 [L,QSA]

# ----------------------------------------------------------------------
# 7. USER SPA ROUTING
# ----------------------------------------------------------------------
# Everything else (like /services) goes to index.php?p=services
# This keeps the SPA logic working with Clean URLs
RewriteRule ^(.*)$ index.php?p=$1 [L,QSA]

# ----------------------------------------------------------------------
# 8. SECURITY HEADERS
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------------------
# 9. CUSTOM ERROR DOCUMENTS
# ----------------------------------------------------------------------
ErrorDocument 404 views/404.php
ErrorDocument 403 views/404.php
